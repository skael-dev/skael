# Required
DATABASE_URL=postgres://skael:skael@localhost:5432/skael?sslmode=disable

# Optional
STORAGE_PATH=./data/skills   # or s3://bucket/prefix for S3-compatible object storage
LISTEN_ADDR=:8080
LOG_FORMAT=pretty
# COOKIE_SECURE=true      # enable in production behind TLS
# DISABLE_SIGNUP=true     # lock down after initial setup

# S3 storage (only when STORAGE_PATH=s3://...). Omit keys to use an IAM instance role.
# S3_ENDPOINT=s3.amazonaws.com   # set for MinIO/R2/Spaces
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_USE_PATH_STYLE=true         # for MinIO
# S3_USE_SSL=true
